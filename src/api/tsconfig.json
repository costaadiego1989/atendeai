{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "paths": {
      "@shared/*": [
        "shared/*"
      ],
      "@modules/*": [
        "modules/*"
      ],
      "@nestjs/bullmq": [
        "node_modules/@nestjs/bullmq"
      ],
      "@nestjs/bullmq/lib/*": [
        "node_modules/@nestjs/bullmq/dist/*"
      ],
      "@langchain/langgraph/prebuilt": [
        "node_modules/@langchain/langgraph/dist/prebuilt/index.d.ts"
      ],
      "@langchain/langgraph": [
        "node_modules/@langchain/langgraph/dist/index.d.ts"
      ]
    }
  },
  "exclude": [
    "node_modules",
    "dist",
    "test",
    "../../app",
    "../../web",
    "**/*.spec.ts",
    "**/*.e2e-spec.ts"
  ],
  "include": [
    "**/*.ts",
    "typings/**/*.d.ts"
  ]
}