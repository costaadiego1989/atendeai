// --- Automations Self-Service ---
model Automation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  isActive    Boolean  @default(false) @map("is_active")
  trigger     Json // { type, config } — event trigger definition
  conditions  Json?    @default("[]") // filter conditions array
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  steps      AutomationStep[]
  executions AutomationExecution[]

  @@index([tenantId, isActive], name: "idx_automations_tenant_active")
  @@map("automations")
  @@schema("tenant_schema")
}

model AutomationStep {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  automationId String  @map("automation_id") @db.Uuid
  order        Int     @default(0)
  type         String  @db.VarChar(50) // send_message, wait_delay, condition_branch, http_request, update_contact, add_tag
  config       Json // step-specific configuration
  nextStepId   String? @map("next_step_id") @db.Uuid

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId, order], name: "idx_automation_steps_order")
  @@map("automation_steps")
  @@schema("tenant_schema")
}

model AutomationExecution {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  automationId String    @map("automation_id") @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  contactId    String?   @map("contact_id") @db.Uuid
  status       String    @default("RUNNING") @db.VarChar(20) // RUNNING, COMPLETED, FAILED, CANCELLED
  currentStep  Int       @default(0) @map("current_step")
  context      Json?     @default("{}") // execution context/variables
  startedAt    DateTime  @default(now()) @map("started_at") @db.Timestamptz
  completedAt  DateTime? @map("completed_at") @db.Timestamptz
  error        String?   @db.Text

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([tenantId, status], name: "idx_automation_executions_tenant_status")
  @@index([automationId, status], name: "idx_automation_executions_automation_status")
  @@map("automation_executions")
  @@schema("tenant_schema")
}
