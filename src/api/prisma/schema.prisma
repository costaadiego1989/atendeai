generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
  schemas  = ["tenant_schema", "contact_schema", "catalog_schema", "inventory_schema", "recovery_schema", "messaging_schema", "ai_schema", "billing_schema", "sales_schema", "prospecting_schema", "shared_schema", "payment_schema", "commerce_schema", "social_schema", "scheduling_schema", "support_schema"]
}

// --- Tenant Module ---
model Tenant {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyName     String           @map("company_name") @db.VarChar(255)
  cnpj            String           @unique @db.VarChar(18)
  plan            String           @default("TRIAL") @db.VarChar(20)
  planStatus      String           @default("ACTIVE") @map("plan_status") @db.VarChar(20)
  apiKey          String           @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  businessType    String?          @map("business_type") @db.VarChar(100)
  ownerBirthDate  DateTime?        @map("owner_birth_date") @db.Date
  description     String?          @db.Text
  services        String?          @db.Text
  zipcode         String?          @db.VarChar(20)
  street          String?          @db.Text
  streetNumber    String?          @map("street_number") @db.VarChar(30)
  neighborhood    String?          @db.VarChar(100)
  city            String?          @db.VarChar(100)
  state           String?          @db.VarChar(50)
  catalogUrl      String?          @map("catalog_url") @db.Text
  catalogFiles    Json?            @default("[]") @map("catalog_files")
  operatingHours  Json?            @map("operating_hours")
  ownerUserId     String?          @map("owner_user_id") @db.Uuid
  promotions      Json?            @default("[]")
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  users          User[]
  whatsappConfig  WhatsAppConfig?
  aiConfig        AIConfig?
  agentRules      TenantAgentRule[]
  salesCommissionDefaults TenantSalesCommissionDefaults?

  @@map("tenants")
  @@schema("tenant_schema")
}

model TenantFinancialAccount {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @unique @map("tenant_id") @db.Uuid
  provider       String   @default("ASAAS") @db.VarChar(20)
  asaasAccountId String   @map("asaas_account_id") @db.VarChar(80)
  walletId       String   @map("wallet_id") @db.VarChar(80)
  status         String   @default("PENDING") @db.VarChar(30)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("tenant_financial_accounts")
  @@schema("tenant_schema")
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  name         String   @db.VarChar(255)
  email        String   @unique @db.VarChar(255)
  cpf          String?  @db.VarChar(14)
  phone        String   @db.VarChar(20)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  mustChangePassword Boolean @default(false) @map("must_change_password")
  role         String   @default("AGENT") @db.VarChar(20)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  salesProfile TenantUserSalesProfile?

  @@map("users")
  @@schema("tenant_schema")
}

model WhatsAppConfig {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @unique @map("tenant_id") @db.Uuid
  provider       String   @default("BUBBLEWHATS") @db.VarChar(30)
  credentials    Json     @default("{}")
  whatsappNumber String   @map("whatsapp_number") @db.VarChar(20)
  webhookSecret  String?  @map("webhook_secret") @db.VarChar(255)
  status         String   @default("PENDING_VERIFICATION") @db.VarChar(30)
  configuredAt   DateTime @default(now()) @map("configured_at") @db.Timestamptz
  tenant         Tenant   @relation(fields: [tenantId], references: [id])

  @@map("whatsapp_configs")
  @@schema("tenant_schema")
}

model InstagramConfig {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String   @unique @map("tenant_id") @db.Uuid
  metaAccessToken    String   @map("meta_access_token") @db.Text
  instagramAccountId String   @map("instagram_account_id") @db.VarChar(255)
  webhookSecret      String   @map("webhook_secret") @db.VarChar(255)
  status             String   @default("PENDING_VERIFICATION") @db.VarChar(30)
  configuredAt       DateTime @default(now()) @map("configured_at") @db.Timestamptz

  @@map("instagram_configs")
  @@schema("tenant_schema")
}

model AIConfig {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String   @unique @map("tenant_id") @db.Uuid
  systemPrompt         String   @map("system_prompt")
  tone                 String   @default("FRIENDLY") @db.VarChar(30)
  language             String   @default("pt-BR") @db.VarChar(10)
  maxTokensPerResponse Int      @default(500) @map("max_tokens_per_response")
  confidenceThreshold  Decimal  @default(0.70) @map("confidence_threshold") @db.Decimal(3, 2)
  escalationMessage    String?  @map("escalation_message")
  businessRules        Json?    @default("[]") @map("business_rules")
  salesInstructions    String?  @map("sales_instructions") @db.Text
  updatedAt            DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  tenant               Tenant   @relation(fields: [tenantId], references: [id])

  @@map("ai_configs")
  @@schema("tenant_schema")
}



model TenantAgentRule {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  branchId         String?  @map("branch_id") @db.Uuid
  moduleId         String   @map("module_id") @db.VarChar(50)
  customPrompt     String   @map("custom_prompt") @db.Text
  isActive         Boolean  @default(true) @map("is_active")
  fallbackToGlobal Boolean  @default(true) @map("fallback_to_global")
  revision         Int      @default(1)
  notes            String?  @db.Text
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  updatedByUserId  String?  @map("updated_by_user_id") @db.Uuid
  updatedByUserName String? @map("updated_by_user_name") @db.VarChar(255)
  tenant           Tenant   @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, moduleId], name: "uq_tenant_agent_rules")
  @@map("tenant_agent_rules")
  @@schema("tenant_schema")
}

model TenantAgentRuleHistory {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String   @map("tenant_id") @db.Uuid
  branchId         String?  @map("branch_id") @db.Uuid
  moduleId         String   @map("module_id") @db.VarChar(50)
  customPrompt     String   @map("custom_prompt") @db.Text
  revision         Int
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedByUserId  String?  @map("updated_by_user_id") @db.Uuid
  updatedByUserName String? @map("updated_by_user_name") @db.VarChar(255)

  @@index([tenantId, moduleId], name: "idx_agent_rule_history_lookup")
  @@map("tenant_agent_rule_history")
  @@schema("tenant_schema")
}

model TenantPDFResume {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  fileName  String   @map("file_name") @db.VarChar(255)
  fileUrl   String?  @map("file_url") @db.Text
  checksum  String?  @db.VarChar(128)
  summaries Json     @default("[]")
  status    String   @default("PROCESSING") @db.VarChar(20)
  error     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, status], name: "idx_tenant_pdf_resumes_tenant_status")
  @@map("tenant_pdf_resumes")
  @@schema("tenant_schema")
}

model TenantSalesCommissionDefaults {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId              String   @unique @map("tenant_id") @db.Uuid
  basePercent           Decimal? @map("base_percent") @db.Decimal(9, 4)
  baseFixedAmount       Decimal? @map("base_fixed_amount") @db.Decimal(12, 2)
  commissionCombineMode String   @default("STACKED") @map("commission_combine_mode") @db.VarChar(20)
  effectiveFrom         DateTime @default(now()) @map("effective_from") @db.Timestamptz
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_sales_commission_defaults")
  @@schema("tenant_schema")
}

model TenantUserSalesProfile {
  id                        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId                  String   @map("tenant_id") @db.Uuid
  userId                    String   @unique @map("user_id") @db.Uuid
  commissionPercentOverride Decimal? @map("commission_percent_override") @db.Decimal(9, 4)
  commissionFixedOverride   Decimal? @map("commission_fixed_override") @db.Decimal(12, 2)
  monthlySalesCountTarget   Int?     @map("monthly_sales_count_target")
  monthlySalesAmountTarget  Decimal? @map("monthly_sales_amount_target") @db.Decimal(12, 2)
  createdAt                 DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  user                      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId], name: "uq_tenant_user_sales_profile")
  @@index([tenantId], name: "idx_tusp_tenant")
  @@map("tenant_user_sales_profiles")
  @@schema("tenant_schema")
}

// --- Contact Module ---
model Contact {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String         @map("tenant_id") @db.Uuid
  name            String         @db.VarChar(255)
  phone           String         @db.VarChar(20)
  email           String?        @db.VarChar(255)
  stage           String         @default("LEAD") @db.VarChar(20)
  tags            Json?          @default("[]")
  notes           String?
  lastInteraction DateTime?      @map("last_interaction") @db.Timestamptz
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  conversations   Conversation[]

  @@unique([tenantId, id])
  @@unique([tenantId, phone])
  @@index([tenantId, stage], name: "idx_contacts_tenant_stage")
  @@index([tenantId, phone], name: "idx_contacts_tenant_phone")
  @@map("contacts")
  @@schema("contact_schema")
}

model ContactFinancialProfile {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  contactId      String   @map("contact_id") @db.Uuid
  provider       String   @default("ASAAS") @db.VarChar(20)
  asaasCustomerId String  @map("asaas_customer_id") @db.VarChar(80)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, contactId], name: "uq_contact_financial_profiles_tenant_contact")
  @@map("contact_financial_profiles")
  @@schema("contact_schema")
}

// --- Catalog Module ---
model CatalogCategory {
  id          String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String        @map("tenant_id") @db.Uuid
  parentCategoryId String?  @map("parent_category_id") @db.Uuid
  name        String        @db.VarChar(255)
  description String?       @db.Text
  path        String[]      @default([])
  level       Int           @default(0)
  active      Boolean       @default(true)
  createdAt   DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  items       CatalogItem[]
  parent      CatalogCategory? @relation("CatalogCategoryTree", fields: [parentCategoryId], references: [id])
  children    CatalogCategory[] @relation("CatalogCategoryTree")

  @@index([tenantId, active], name: "idx_catalog_categories_tenant_active")
  @@index([tenantId, parentCategoryId, active], name: "idx_catalog_categories_parent")
  @@unique([tenantId, name], name: "uq_catalog_categories_tenant_name")
  @@map("catalog_categories")
  @@schema("catalog_schema")
}

model CatalogItem {
  id                String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String           @map("tenant_id") @db.Uuid
  categoryId        String?          @map("category_id") @db.Uuid
  type              String           @db.VarChar(30)
  name              String           @db.VarChar(255)
  description       String?          @db.Text
  basePrice         Decimal?         @map("base_price") @db.Decimal(12, 2)
  currency          String           @default("BRL") @db.VarChar(10)
  tags              Json?            @default("[]")
  active            Boolean          @default(true)
  source            String           @default("MANUAL") @db.VarChar(30)
  externalReference String?          @map("external_reference") @db.VarChar(255)
  imageUrl          String?          @map("image_url") @db.Text
  attributes        Json             @default("{}")
  variants          Json             @default("[]")
  optionGroups      Json             @default("[]") @map("option_groups")
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  category          CatalogCategory? @relation(fields: [categoryId], references: [id])

  @@index([tenantId, type, active], name: "idx_catalog_items_tenant_type_active")
  @@index([tenantId, categoryId], name: "idx_catalog_items_tenant_category")
  @@map("catalog_items")
  @@schema("catalog_schema")
}

model CatalogAuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  userName  String?  @map("user_name") @db.VarChar(255)
  event     String   @db.VarChar(50) // ITEM_CREATED, ITEM_UPDATED, ITEM_DEACTIVATED, CATEGORY_CREATED, etc.
  entityId  String   @map("entity_id") @db.Uuid
  entityType String  @map("entity_type") @db.VarChar(30) // ITEM, CATEGORY
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId])
  @@index([entityId])
  @@map("catalog_audit_log")
  @@schema("catalog_schema")
}

// --- Inventory Module ---
model InventoryItem {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  catalogItemId     String?  @map("catalog_item_id") @db.Uuid
  sku               String   @db.VarChar(100)
  externalReference String?  @map("external_reference") @db.VarChar(255)
  name              String   @db.VarChar(255)
  availableQuantity Int      @default(0) @map("available_quantity")
  availabilityStatus String  @default("AVAILABLE") @map("availability_status") @db.VarChar(30)
  currentPrice      Decimal? @map("current_price") @db.Decimal(12, 2)
  currency          String   @default("BRL") @db.VarChar(10)
  source            String   @default("MANUAL_SNAPSHOT") @db.VarChar(30)
  lastSyncedAt      DateTime @default(now()) @map("last_synced_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([tenantId, sku])
  @@index([tenantId, availabilityStatus], name: "idx_inventory_items_tenant_status")
  @@index([tenantId, catalogItemId], name: "idx_inventory_items_tenant_catalog")
  @@map("inventory_items")
  @@schema("inventory_schema")
}

model InventoryConnection {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  sourceType   String   @map("source_type") @db.VarChar(30)
  providerName String   @map("provider_name") @db.VarChar(255)
  status       String   @default("ACTIVE") @db.VarChar(20)
  config       Json     @default("{}")
  lastSyncedAt DateTime? @map("last_synced_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, sourceType], name: "idx_inventory_connections_tenant_source")
  @@map("inventory_connections")
  @@schema("inventory_schema")
}

model RecoveryCase {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  contactId         String?  @map("contact_id") @db.Uuid
  debtorName        String   @map("debtor_name") @db.VarChar(255)
  debtorCompanyName String?  @map("debtor_company_name") @db.VarChar(255)
  debtorDocument    String?  @map("debtor_document") @db.VarChar(30)
  phone             String   @db.VarChar(30)
  externalReference String?  @map("external_reference") @db.VarChar(255)
  paymentReference  String?  @unique @map("payment_reference") @db.VarChar(255)
  source            String   @default("MANUAL") @db.VarChar(20)
  chargeType        String?  @map("charge_type") @db.VarChar(50)
  chargeTitle       String?  @map("charge_title") @db.VarChar(255)
  chargeDescription String?  @map("charge_description") @db.Text
  referencePeriod   String?  @map("reference_period") @db.VarChar(30)
  relatedEntityType String?  @map("related_entity_type") @db.VarChar(50)
  relatedEntityId   String?  @map("related_entity_id") @db.VarChar(255)
  relatedEntityLabel String? @map("related_entity_label") @db.VarChar(255)
  amountDue         Decimal? @map("amount_due") @db.Decimal(12, 2)
  dueDate           DateTime? @map("due_date") @db.Date
  status            String   @default("READY_TO_CONTACT") @db.VarChar(30)
  assignedTags      Json?    @default("[]") @map("assigned_tags")
  lastContactedAt   DateTime? @map("last_contacted_at") @db.Timestamptz
  nextActionAt      DateTime? @map("next_action_at") @db.Timestamptz
  paidAt            DateTime? @map("paid_at") @db.Timestamptz
  suggestedReply    String?  @map("suggested_reply") @db.Text
  suggestedNextAction String? @map("suggested_next_action") @db.Text
  guidanceGeneratedAt DateTime? @map("guidance_generated_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, status], name: "idx_recovery_cases_tenant_status")
  @@index([tenantId, source], name: "idx_recovery_cases_tenant_source")
  @@map("recovery_cases")
  @@schema("recovery_schema")
}

model CommerceAuditLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  userName  String?  @map("user_name") @db.VarChar(255)
  event     String   @db.VarChar(50) // SESSION_STARTED, CHECKOUT_CREATED, ORDER_PAID, ORDER_STATUS_CHANGED, SHIPPING_UPDATED
  entityId  String   @map("entity_id") @db.Uuid
  entityType String  @map("entity_type") @db.VarChar(30) // SESSION, ORDER, SHIPPING_POLICY
  metadata  Json?    @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([tenantId])
  @@index([entityId])
  @@map("commerce_audit_log")
  @@schema("commerce_schema")
}

model CommerceAbandonmentConfig {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId          String   @unique @map("tenant_id") @db.Uuid
  active            Boolean  @default(true)
  message           String?  @db.Text
  useAiMessage      Boolean  @default(true) @map("use_ai_message")
  mode              String   @default("SINGLE") @db.VarChar(20)
  maxTouches        Int      @default(3) @map("max_touches")
  intervalMinutes   Int      @default(60) @map("interval_minutes")
  minimumIntervalMinutes Int @default(30) @map("minimum_interval_minutes")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz

  @@map("commerce_abandonment_configs")
  @@schema("commerce_schema")
}

// --- Messaging Module ---
model Conversation {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId             String    @map("tenant_id") @db.Uuid
  contactId            String    @map("contact_id") @db.Uuid
  branchId             String?   @map("branch_id") @db.Uuid
  channel              String    @default("WHATSAPP") @db.VarChar(20)
  status               String    @default("ACTIVE") @db.VarChar(30)
  assignedUserId       String?   @map("assigned_user_id") @db.Uuid
  assignedAt           DateTime? @map("assigned_at") @db.Timestamptz
  releasedAt           DateTime? @map("released_at") @db.Timestamptz
  unreadCount          Int       @default(0) @map("unread_count")
  lastInboundAt        DateTime? @map("last_inbound_at") @db.Timestamptz
  lastOutboundAt       DateTime? @map("last_outbound_at") @db.Timestamptz
  lastMessageAt        DateTime? @map("last_message_at") @db.Timestamptz
  lastMessageDirection String?   @map("last_message_direction") @db.VarChar(10)
  lastMessagePreview   String?   @map("last_message_preview") @db.Text
  lastReadAt           DateTime? @map("last_read_at") @db.Timestamptz
  lastReadSortOrder    BigInt?   @map("last_read_sort_order")
  startedAt            DateTime  @default(now()) @map("started_at") @db.Timestamptz
  closedAt             DateTime? @map("closed_at") @db.Timestamptz
  updatedAt            DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  contact              Contact   @relation(fields: [contactId], references: [id])
  messages             Message[]

  @@index([tenantId, status], name: "idx_conversations_tenant_status")
  @@index([contactId, status], name: "idx_conversations_contact")
  @@index([tenantId, branchId, status], name: "idx_conversations_tenant_branch_status")
  @@index([tenantId, assignedUserId], name: "idx_conversations_tenant_assigned")
  @@map("conversations")
  @@schema("messaging_schema")
}

model Message {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String       @map("conversation_id") @db.Uuid
  direction      String       @db.VarChar(10)
  contentType    String       @default("TEXT") @map("content_type") @db.VarChar(20)
  content        Json
  sentBy         String       @map("sent_by") @db.VarChar(10)
  deliveryStatus String       @default("PENDING") @map("delivery_status") @db.VarChar(20)
