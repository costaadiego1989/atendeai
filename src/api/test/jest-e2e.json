{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@shared/(.*)$": "<rootDir>/shared/$1",
    "^@modules/(.*)$": "<rootDir>/modules/$1",
    "^(\\.\\.?/.*)\\.js$": "$1"
  }
}
