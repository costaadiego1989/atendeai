# =============================================================================
# Render.com (produção): defina estas variáveis no Dashboard do Web Service.
# Não uses 127.0.0.1 / localhost — são URLs internas dos serviços geridos Render.
#
# PRISMA_DATABASE_URL → Postgres → "Internal Database URL" (mesma região que a API).
# REDIS_HOST / REDIS_PORT → Redis gerido → hostname interno + porta (geralmente 6379).
# =============================================================================

PRISMA_DATABASE_URL=postgresql://atendeai:atendeai_dev@127.0.0.1:5434/atendeai?schema=public
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5434
DATABASE_USER=atendeai
DATABASE_PASSWORD=atendeai_dev
DATABASE_NAME=atendeai

# Recovery: ao definir true, novos casos recebem o playbook activo do tenant (filial ou tenant-wide).
RECOVERY_PLAYBOOKS_ENABLED=false

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Limite opcional HTTP auth (Redis): contadores separados por IP e por device-id (cookie, header ou fingerprint estável)
AUTH_THROTTLE_LIMIT=12
AUTH_THROTTLE_TTL_SEC=900

EVENT_BUS_MODE=immediate
EVENT_BUS_TRANSPORT=bullmq
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=50
RABBITMQ_URL=amqp://guest:guest@127.0.0.1:5672
RABBITMQ_EXCHANGE=atendeai.events
RABBITMQ_DLX=atendeai.events.dlx
RABBITMQ_QUEUE_PREFIX=atendeai

BUBBLEWHATS_ID=change-me
BUBBLEWHATS_TOKEN=change-me
BUBBLEWHATS_API_URL=https://example.bubblewhats.com
D360_BASE_URL=https://waba-v2.360dialog.io
D360_DEFAULT_WEBHOOK_URL=https://your-public-app.com/api/v1/webhooks/whatsapp
APP_PUBLIC_BASE_URL=https://your-public-app.com
TWILIO_ACCOUNT_SID=change-me
TWILIO_AUTH_TOKEN=change-me
TWILIO_API_BASE_URL=https://api.twilio.com/2010-04-01
TWILIO_MESSAGING_BASE_URL=https://messaging.twilio.com/v2
TWILIO_WHATSAPP_WEBHOOK_URL=https://your-public-app.com/api/v1/webhooks/whatsapp
TWILIO_WHATSAPP_STATUS_CALLBACK_URL=https://your-public-app.com/api/v1/webhooks/twilio/status
TWILIO_EMBEDDED_SIGNUP_APP_ID=change-me
TWILIO_EMBEDDED_SIGNUP_CONFIGURATION_ID=change-me
TWILIO_EMBEDDED_SIGNUP_SOLUTION_ID=change-me

DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
GOOGLE_PLACES_API_KEY=change-me
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/prospecting/ads/connection/callback
GOOGLE_ADS_STATE_SECRET=change-me-google-ads-state
GOOGLE_CALENDAR_CLIENT_ID=change-me
GOOGLE_CALENDAR_CLIENT_SECRET=change-me
GOOGLE_CALENDAR_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/scheduling/google-calendar/connection/callback
GOOGLE_CALENDAR_STATE_SECRET=change-me-google-calendar-state

SCHEDULING_REMINDER_TIMEZONE=America/Sao_Paulo
SCHEDULING_PENDING_PAYMENT_TIMEOUT_HOURS=3

APP_PORT=3000
NODE_ENV=development

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
AUTH_RESET_PASSWORD_URL_BASE=http://localhost:8080/reset-password
APP_LOGIN_URL_BASE=http://localhost:8080/login
BREVO_SMTP_LOGIN=change-me
BREVO_SMTP_KEY=change-me
BREVO_SMTP_SENDER_EMAIL=no-reply@atendeai.local
BREVO_SMTP_SENDER_NAME=AtendeAi

ASAAS_API_KEY=change-me
ASAAS_SANDBOX=true
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_SUCCESS_URL=https://your-app.com/payment/success
ASAAS_WEBHOOK_SECRET=change-me

PLAN_MESSAGES_QUOTA_ESSENCIAL=250
PLAN_AI_TOKENS_QUOTA_ESSENCIAL=10000
PLAN_CONTACTS_QUOTA_ESSENCIAL=5000
PLAN_MESSAGES_QUOTA_PROFISSIONAL=1250
PLAN_AI_TOKENS_QUOTA_PROFISSIONAL=40000
PLAN_CONTACTS_QUOTA_PROFISSIONAL=50000
PLAN_MESSAGES_QUOTA_ESCALA=12500
PLAN_AI_TOKENS_QUOTA_ESCALA=200000
PLAN_CONTACTS_QUOTA_ESCALA=500000

# Platform admin (API key header x-platform-admin-key)
PLATFORM_ADMIN_API_KEY=change-me-long-random-secret

# OpenTelemetry (optional — point to local collector or Grafana stack)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://127.0.0.1:4318
# OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://127.0.0.1:4318/v1/logs
# OTEL_SERVICE_NAME=atendeai-api
# OTEL_TRACES_SAMPLER_ARG=1
# STRUCTURED_LOG_STDOUT=true

# =============================================================================
# Voice Agent (Agente de Voz com IA)
# =============================================================================
# ElevenLabs — Text-to-Speech (voz natural PT-BR)
# Obtenha sua API key em: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=change-me
ELEVENLABS_BASE_URL=https://api.elevenlabs.io/v1
ELEVENLABS_DEFAULT_VOICE_ID=change-me

# Deepgram — Speech-to-Text (transcrição em tempo real)
# Obtenha sua API key em: https://console.deepgram.com/project/settings/api-keys
DEEPGRAM_API_KEY=change-me
DEEPGRAM_BASE_URL=https://api.deepgram.com/v1

# Twilio Voice (já configurado acima para WhatsApp — reutiliza TWILIO_ACCOUNT_SID e TWILIO_AUTH_TOKEN)
# Número de voz Twilio para ligações outbound
# Compre um número em: https://console.twilio.com/us1/develop/phone-numbers/manage/incoming
TWILIO_VOICE_PHONE_NUMBER=+5511999999999
TWILIO_VOICE_WEBHOOK_URL=https://your-public-app.com/api/v1/voice/webhook/incoming
TWILIO_VOICE_STATUS_CALLBACK_URL=https://your-public-app.com/api/v1/voice/webhook/status

# =============================================================================
# Promo Discount (Desconto promocional de lançamento)
# =============================================================================
# Percentual de desconto (0-100). Ex: 20 = 20% off.
PROMO_DISCOUNT_ANNUAL=20
PROMO_DISCOUNT_MONTHLY=20

# =============================================================================
# Meta / Instagram OAuth (Social module)
# =============================================================================
# App ID e App Secret: Meta App Dashboard → Configurações Básicas
META_APP_ID=change-me
META_APP_SECRET=change-me
META_GRAPH_API_VERSION=v21.0
META_WEBHOOK_VERIFY_TOKEN=change-me
# URL de callback do Social OAuth — registrar em: Meta App → Facebook Login → "Autorizar URL de retorno de chamada"
# Atenção: diferente de META_INSTAGRAM_OAUTH_REDIRECT_URI (usada pelo módulo de canais/messaging)
META_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/social/oauth/instagram/callback
# URL do frontend para redirecionar após OAuth bem-sucedido (aba Canais Integrados)
META_OAUTH_SUCCESS_URL=http://localhost:5173/app/social

# --- Instagram OAuth do módulo de Canais (Settings → Channels) ---
# URL de callback registrada em: Meta App → Login do Facebook para Empresas → URIs de redirecionamento OAuth válidos.
META_INSTAGRAM_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/channels/instagram/meta/callback
# Configuration ID do "Login do Facebook para Empresas".
# Obrigatório para apps do tipo Empresa: as permissões vêm da configuração (config_id),
# não do parâmetro scope. Sem isto o Meta rejeita com "no supported permission".
# Meta App → Login do Facebook para Empresas → Configurações → Criar configuração.
# Se vazio, o fluxo cai no Login do Facebook clássico via scope.
META_INSTAGRAM_LOGIN_CONFIG_ID=change-me

# --- WhatsApp Cloud API (Meta) — ADR-0030 ---
# Token de verificação do webhook do WhatsApp (handshake GET hub.verify_token).
# Registrar o mesmo valor em: Meta App → WhatsApp → Configuração → Webhook.
META_WHATSAPP_WEBHOOK_VERIFY_TOKEN=change-me
# Configuration ID do Embedded Signup do WhatsApp (Meta App → Login do Facebook para Empresas → Configurações).
# Usado pelo frontend para iniciar o fluxo de conexão.
META_WHATSAPP_CONFIGURATION_ID=change-me
# URL pública HTTPS do webhook do WhatsApp (registrar em: Meta App → WhatsApp → Configuração → Webhook → URL de callback).
# Em desenvolvimento, usar ngrok ou similar: https://xxxx.ngrok.io/api/v1/webhooks/whatsapp
META_WHATSAPP_WEBHOOK_URL=https://your-public-app.com/api/v1/webhooks/whatsapp

# Inventory credential encryption (AES-256-GCM)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INVENTORY_CONFIG_ENCRYPTION_KEY=change-me-32-byte-hex
