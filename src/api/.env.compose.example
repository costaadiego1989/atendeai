# IMPORTANT: If any value contains a '$', escape it with '$$' for Docker Compose compatibility (e.g. KEY=$$value)
PRISMA_DATABASE_URL=postgresql://atendeai:atendeai_dev@postgres:5432/atendeai?schema=public
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=atendeai
DATABASE_PASSWORD=atendeai_dev
DATABASE_NAME=atendeai

REDIS_HOST=redis
REDIS_PORT=6379

EVENT_BUS_MODE=immediate
EVENT_BUS_TRANSPORT=bullmq
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EXCHANGE=atendeai.events
RABBITMQ_DLX=atendeai.events.dlx
RABBITMQ_QUEUE_PREFIX=atendeai

APP_PORT=3000
NODE_ENV=development

# Compose: portas hospedeiro (observabilidade no mesmo arquivo que API/workers)
TEMPO_HTTP_PORT=3200
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
OTEL_PROMETHEUS_PORT=9464
GRAFANA_HTTP_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

LOKI_HTTP_PORT=3100
OTEL_TRACES_SAMPLER_ARG=1
OTEL_EXPORTER_OTLP_LOGS_ENDPOINT=http://otel-collector:4318/v1/logs
STRUCTURED_LOG_STDOUT=true

# OpenTelemetry (Compose injeta OTLP também no anchor do docker-compose.yml)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
OTEL_SERVICE_NAME=atendeai

# Platform admin (/api/v1/platform/...) — header x-platform-admin-key
PLATFORM_ADMIN_API_KEY=change-me-long-random-platform-secret

JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
AUTH_RESET_PASSWORD_URL_BASE=http://localhost:8080/reset-password
BREVO_SMTP_LOGIN=change-me
BREVO_SMTP_KEY=change-me
BREVO_SMTP_SENDER_EMAIL=no-reply@atendeai.local
BREVO_SMTP_SENDER_NAME=AtendeAi

BUBBLEWHATS_ID=change-me
BUBBLEWHATS_TOKEN=change-me
BUBBLEWHATS_API_URL=https://example.bubblewhats.com
APP_PUBLIC_BASE_URL=https://your-public-app.com
TWILIO_ACCOUNT_SID=change-me
TWILIO_AUTH_TOKEN=change-me
TWILIO_API_BASE_URL=https://api.twilio.com/2010-04-01
TWILIO_MESSAGING_BASE_URL=https://messaging.twilio.com/v2
TWILIO_WHATSAPP_WEBHOOK_URL=https://your-public-app.com/api/v1/webhooks/whatsapp
TWILIO_WHATSAPP_STATUS_CALLBACK_URL=https://your-public-app.com/api/v1/webhooks/twilio/status
TWILIO_EMBEDDED_SIGNUP_APP_ID=change-me
TWILIO_EMBEDDED_SIGNUP_CONFIGURATION_ID=change-me
TWILIO_EMBEDDED_SIGNUP_SOLUTION_ID=change-me

DEEPSEEK_API_KEY=change-me
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

ASAAS_API_KEY=change-me
ASAAS_SANDBOX=true
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3
ASAAS_SUCCESS_URL=https://your-app.com/payment/success
ASAAS_WEBHOOK_SECRET=change-me

PLAN_MESSAGES_QUOTA_ESSENCIAL=250
PLAN_AI_TOKENS_QUOTA_ESSENCIAL=10000
PLAN_CONTACTS_QUOTA_ESSENCIAL=5000
PLAN_MESSAGES_QUOTA_PROFISSIONAL=1250
PLAN_AI_TOKENS_QUOTA_PROFISSIONAL=40000
PLAN_CONTACTS_QUOTA_PROFISSIONAL=50000
PLAN_MESSAGES_QUOTA_ESCALA=12500
PLAN_AI_TOKENS_QUOTA_ESCALA=200000
PLAN_CONTACTS_QUOTA_ESCALA=500000

GOOGLE_PLACES_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_OAUTH_REDIRECT_URI=http://localhost:3000/api/v1/prospecting/ads/connection/callback
GOOGLE_ADS_STATE_SECRET=change-me-google-ads-state
PROSPECT_WEBSITE_TIMEOUT_MS=5000
