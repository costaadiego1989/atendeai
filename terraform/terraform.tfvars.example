aws_region  = "us-east-1"
project_name = "atendeai"
environment  = "dev"

# Never commit real passwords in terraform.tfvars.
db_password = "CHANGE_ME"
mq_password = "CHANGE_ME"

# Use the same tag published by the build pipeline.
image_tag = "latest"

ec2_instance_type    = "t3.medium"
asg_min_size         = 1
asg_desired_capacity = 1
asg_max_size         = 1

# Optional: set these when using images outside the ECR repositories created here.
api_image_uri = null
app_image_uri = null
web_image_uri = null

api_desired_count    = 1
app_desired_count    = 1
web_desired_count    = 1
worker_desired_count = 1
