{
  "name": "atendeai",
  "private": true,
  "description": "AtendeAi Enterprise Monorepo",
  "workspaces": [
    "src/app",
    "src/api",
    "src/web"
  ],
  "optionalDependencies": {
    "@esbuild/linux-x64": "^0.20.0",
    "@rollup/rollup-linux-x64-gnu": "^4.0.0",
    "@rollup/rollup-linux-x64-musl": "^4.0.0",
    "@swc/core-linux-x64-gnu": "^1.3.0",
    "@swc/core-linux-x64-musl": "^1.3.0"
  },
  "scripts": {
    "install:all": "npm install",
    "build": "npm run build:api",
    "build:app": "npm run build --workspace=src/app",
    "build:api": "npm run build --workspace=src/api",
    "build:web": "npm run build --workspace=src/web",
    "dev:app": "npm run dev --workspace=src/app",
    "dev:api": "npm run dev --workspace=src/api",
    "dev:web": "npm run dev --workspace=src/web",
    "prisma:generate": "npm run prisma:generate --workspace=src/api",
    "start:prod": "npm run start:prod --workspace=src/api",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:headed:debug": "playwright test --headed --debug",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "test:e2e:install": "npx playwright install --with-deps"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@playwright/mcp": "^0.0.77",
    "@playwright/test": "^1.60.0"
  }
}
